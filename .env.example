# Variables de entorno — copiar a .env y completar valores
# En Railway: configurar estas variables en el dashboard de Railway (no en el repo).

# ─── Base de datos ───────────────────────────────────────────────────────────
# Railway Postgres plugin provee DATABASE_URL automáticamente.
# Para desarrollo local:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lab_db?schema=public"

# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Puerto ──────────────────────────────────────────────────────────────────
# Railway asigna PORT automáticamente en producción.
PORT=3000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generar secreto fuerte: openssl rand -base64 48
JWT_SECRET=CAMBIA_ESTE_SECRETO_ACCESS_POR_UNO_SEGURO_DE_64_CHARS_O_MAS
JWT_EXPIRES_IN=15m

# JWT Refresh Token (larga duración, secreto distinto al access)
JWT_REFRESH_SECRET=CAMBIA_ESTE_SECRETO_REFRESH_POR_UNO_SEGURO_DE_64_CHARS_O_MAS
JWT_REFRESH_EXPIRES_IN=7d

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Directorio donde se almacenan los archivos subidos dentro del contenedor.
# En Railway: configurar como volumen persistente montado en /app/uploads.
UPLOAD_DIR=/app/uploads

# ─── CORS (opcional) ─────────────────────────────────────────────────────────
# URL del frontend en Vercel para restringir CORS en producción.
# Ejemplo: https://tu-app.vercel.app
CORS_ORIGIN=http://localhost:3001

