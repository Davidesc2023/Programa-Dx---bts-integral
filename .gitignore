.env
.env.*
!.env.example
!frontend/.env.production.example

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Test coverage ───────────────────────────────────────────────────────────
coverage/

# ─── Prisma generated ────────────────────────────────────────────────────────
prisma/*.db

# ─── Uploads (user-generated content, not source code) ───────────────────────
uploads/
