# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ─── Build outputs ───────────────────────────────────────────────────────────
dist/
frontend/.next/
frontend/out/
# Prevent accidental tsc emit artifacts inside frontend/src
frontend/src/**/*.js
frontend/src/**/*.js.map
frontend/src/**/*.d.ts
# TypeScript incremental build info
*.tsbuildinfo
frontend/*.tsbuildinfo
# Tailwind config artifacts
frontend/tailwind.config.js
frontend/tailwind.config.js.map
frontend/tailwind.config.d.ts

# ─── Environment variables — NEVER commit real secrets ───────────────────────
.env
.env.*
!.env.example
!frontend/.env.production.example

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Test coverage ───────────────────────────────────────────────────────────
coverage/

# ─── Prisma generated ────────────────────────────────────────────────────────
prisma/*.db

# ─── Uploads (user-generated content, not source code) ───────────────────────
uploads/
